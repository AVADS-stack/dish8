{
  "appId": "com.dish8.app",
  "appName": "Dish8",
  "webDir": "dist",
  "server": {
    "url": "https://dish8.vercel.app",
    "cleartext": false,
    "allowNavigation": [
      "dish8.com",
      "*.dish8.com",
      "dish8.vercel.app",
      "*.supabase.co",
      "*.stripe.com",
      "buy.stripe.com"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "backgroundColor": "#141414",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#141414",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true,
      "style": "DARK"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "ios": {
    "scheme": "Dish8",
    "contentInset": "always",
    "backgroundColor": "#141414",
    "preferredContentMode": "mobile",
    "scrollEnabled": true,
    "allowsLinkPreview": false
  },
  "android": {
    "backgroundColor": "#141414",
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
