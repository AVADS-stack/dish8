{
  "appId": "com.dish8.app",
  "appName": "Dish8",
  "webDir": "dist",
  "server": {
    "url": "https://www.dish8.com",
    "cleartext": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#141414",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#141414"
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },
  "ios": {
    "scheme": "Dish8",
    "contentInset": "always"
  },
  "android": {
    "backgroundColor": "#141414",
    "allowMixedContent": false
  }
}
