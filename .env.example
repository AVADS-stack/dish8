# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps (for address autocomplete)
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "Places API" and "Maps JavaScript API"
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Stripe Configuration
# Publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Stripe Payment Links — create these in Stripe Dashboard → Payment Links
# Each payment link is a URL like: https://buy.stripe.com/xxxxx
# Create 4 payment links:
VITE_STRIPE_LINK_LUNCH=https://buy.stripe.com/xxx    # Lunch Only — $99.99/month recurring
VITE_STRIPE_LINK_DINNER=https://buy.stripe.com/xxx   # Dinner Only — $99.99/month recurring
VITE_STRIPE_LINK_BOTH=https://buy.stripe.com/xxx     # Lunch & Dinner — $199.99/month recurring
VITE_STRIPE_LINK_MEAL=https://buy.stripe.com/xxx     # Single meal — $9.99 (adjustable quantity)
