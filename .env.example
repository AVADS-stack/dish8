# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Maps (for address autocomplete)
# Get from: https://console.cloud.google.com/apis/credentials
# Enable "Places API" and "Maps JavaScript API"
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Stripe (for payments)
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Stripe Price IDs — create these in Stripe Dashboard → Products
# Each product needs a recurring price (for subscriptions) or one-time price (for meals)
#
# Subscription plans (mode: subscription, recurring monthly):
VITE_STRIPE_PRICE_LUNCH=price_xxx    # Lunch Only — $99.99/month
VITE_STRIPE_PRICE_DINNER=price_xxx   # Dinner Only — $99.99/month
VITE_STRIPE_PRICE_BOTH=price_xxx     # Lunch & Dinner — $199.99/month
#
# Per-meal charge (mode: payment, one-time, used at cart checkout):
VITE_STRIPE_PRICE_MEAL=price_xxx     # Single meal — $9.99 (quantity = number of meals)
